{
  "routes": [
    { "src": "/", "dest": "/mp5nfrlg-john-buladaco-portfolio.html" },
    { "src": "/case-study/matatag", "dest": "/case-study-matatag.html" },
    { "src": "/case-study/pawbook", "dest": "/case-study-pawbook.html" },
    { "src": "/case-study/e27", "dest": "/case-study-e27.html" },
    { "src": "/case-study/kindly", "dest": "/case-study-kindly.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/gifs/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/videos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
